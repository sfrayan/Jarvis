# =============================================================================
# Jarvis — template de variables d'environnement
# Copier ce fichier en `.env` (à la racine) et adapter selon ton setup.
# Le fichier `.env` est gitignore — ne JAMAIS le committer.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
JARVIS_ENV=dev                          # dev | prod
JARVIS_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
JARVIS_CONFIG_PATH=config/default.yaml  # Chemin vers la config YAML principale

# --- Sécurité (voir CLAUDE.md) -----------------------------------------------
# Mode de défaut au premier lancement : dry_run.
# Passage en `autonomous` : modifier ce fichier + le YAML en conscience.
JARVIS_SAFETY_MODE=dry_run              # observe | dry_run | assisted | autonomous
JARVIS_I_UNDERSTAND_THE_RISKS=false     # doit être `true` pour autoriser `autonomous`

# --- Services locaux (dockerisés, cf. docker-compose.yml) --------------------
# Depuis le process Python natif Windows, on joint les conteneurs via
# `host.docker.internal` — pattern identique à `ruleless-digital-twins`.
OLLAMA_BASE_URL=http://host.docker.internal:11434
CHROMADB_BASE_URL=http://host.docker.internal:8000
PIPER_BASE_URL=http://host.docker.internal:10200
N8N_BASE_URL=http://host.docker.internal:5678

# --- Modèles Ollama ----------------------------------------------------------
OLLAMA_ROUTER_MODEL=qwen3:latest         # Intent classification (CHAT vs GUI)
OLLAMA_VISION_MODEL=qwen2.5vl:7b         # GUI grounding local
OLLAMA_EMBED_MODEL=nomic-embed-text      # Embeddings RAG ChromaDB

# --- Cloud fallback (optionnel, désactivé par défaut) ------------------------
# Activer uniquement si besoin explicite. Aucun appel cloud sinon.
JARVIS_CLOUD_FALLBACK=false
ANTHROPIC_API_KEY=                       # Claude Computer Use si fallback activé
OPENROUTER_API_KEY=                      # Routage multi-modèle de secours
